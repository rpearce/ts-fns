{
  "name": "@rpearce/ts-fns",
  "version": "1.2.2",
  "description": "Public domain Typescript helper functions for copying & pasting into projects.",
  "author": "Robert Pearce <me@robertwpearce.com> (https://robertwpearce.com)",
  "license": "Unlicense",
  "type": "module",
  "exports": {
    "./*": "./dist/*.js"
  },
  "sideEffects": false,
  "keywords": [
    "typescript",
    "ts",
    "functional programming",
    "helper functions"
  ],
  "tags": [
    "typescript",
    "ts",
    "functional programming",
    "helper functions"
  ],
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "ci": "run-p lint test build",
    "lint": "oxlint --type-aware",
    "prepack": "run-p lint test && npm run build",
    "release": "changeset publish",
    "test": "node --import tsx --test '__tests__/*.ts'",
    "test:coverage": "node --import tsx --test --experimental-test-coverage '__tests__/*.ts'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
